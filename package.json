{
  "name": "onlist",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for Onlist, the AI API marketplace. Access 200+ AI models (GPT, Claude, Gemini, DeepSeek, Llama) through a unified OpenAI-compatible API with provider routing, marketplace data, and competitive pricing.",
  "keywords": [
    "onlist",
    "ai",
    "api",
    "llm",
    "openai",
    "claude",
    "gpt",
    "gemini",
    "deepseek",
    "llama",
    "marketplace",
    "sdk",
    "openrouter",
    "ai-gateway",
    "provider-routing",
    "typescript",
    "machine-learning",
    "artificial-intelligence"
  ],
  "homepage": "https://onlist.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/OnlistTeam/onlist-js.git"
  },
  "bugs": {
    "url": "https://github.com/OnlistTeam/onlist-js/issues"
  },
  "license": "MIT",
  "author": "Onlist <dev@onlist.io>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openai": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
